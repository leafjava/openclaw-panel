# OpenClaw Panel 环境变量配置
# 复制此文件为 .env 并填写实际值

# OpenAI API Key（用于 AI 评分/分类，兼容 OpenAI / DeepSeek / 通义千问 等）
# 使用 OpenAI 官方: 仅需设置 OPENAI_API_KEY
# 使用第三方（如 DeepSeek）: 需同时设置 OPENAI_BASE_URL 和 OPENAI_MODEL
OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# GitHub Token（可选，提升 API 速率限制 60→5000/小时）
GITHUB_TOKEN=ghp_xxx

# Twitter API Bearer Token（用于抓取推文）
TWITTER_BEARER_TOKEN=xxx

# 要监控的 Twitter 用户（逗号分隔）
TWITTER_USERS=elonmusk,VitalikButerin
